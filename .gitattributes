# ===========================================================================
# .gitattributes — qdls.io
# Auto-detect text files and normalise line endings to LF on commit.
# ===========================================================================

# Default: auto-detect and normalise
* text=auto

# -----------------------------------------------------------------------
# WEB FILES — force LF
# -----------------------------------------------------------------------
*.html         text eol=lf
*.htm          text eol=lf
*.php          text eol=lf
*.css          text eol=lf
*.scss         text eol=lf
*.js           text eol=lf
*.mjs          text eol=lf
*.ts           text eol=lf
*.json         text eol=lf
*.md           text eol=lf
*.markdown     text eol=lf
*.xml          text eol=lf
*.svg          text eol=lf
*.yaml         text eol=lf
*.yml          text eol=lf
*.toml         text eol=lf
*.ini          text eol=lf
*.env          text eol=lf
*.env.example  text eol=lf
*.txt          text eol=lf
*.csv          text eol=lf
*.sql          text eol=lf
*.sh           text eol=lf
*.conf         text eol=lf
*.htaccess     text eol=lf

# -----------------------------------------------------------------------
# CONFIG / DOTFILES
# -----------------------------------------------------------------------
.gitignore     text eol=lf
.gitattributes text eol=lf
Makefile       text eol=lf
Dockerfile     text eol=lf

# -----------------------------------------------------------------------
# BINARY FILES — never diff or convert
# -----------------------------------------------------------------------
# Images
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.webp         binary
*.ico          binary
*.bmp          binary
*.tiff         binary
*.psd          binary

# Fonts
*.woff         binary
*.woff2        binary
*.eot          binary
*.ttf          binary
*.otf          binary

# Documents / Archives
*.pdf          binary
*.zip          binary
*.gz           binary
*.tar          binary
*.rar          binary
*.7z           binary
