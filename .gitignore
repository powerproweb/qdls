# ============================================================
# SECRETS & CREDENTIALS — never commit these
# ============================================================
config.php

# ============================================================
# VENDOR / DEPENDENCIES — install via Composer
# ============================================================
/vendor/

# ============================================================
# STORAGE — runtime data, caches, plugins, user uploads
# ============================================================
/storage/cache/
/storage/plugins/
/storage/logs/
/storage/app/tmp/

# ============================================================
# USER-UPLOADED CONTENT
# ============================================================
/public/content/avatar/
/public/content/blog/
/public/content/files/
/public/content/images/
/public/content/profiles/
/public/content/qr/

# ============================================================
# FILE TYPES
# ============================================================
*.psd
*.db
*.log
*.zip
._*

# ============================================================
# ONE-TIME FIX SCRIPTS — server-only, never commit
# ============================================================
public/fix_*.php

# ============================================================
# BACKUP / BROKEN FILES
# ============================================================
*.bak
*.broke
*.orig
*.tmp
.gitignore.old
.gitattributes.old

# ============================================================
# OS FILES
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# IDE / EDITOR
# ============================================================
/.dist/
/.vscode/
.idea/
*.sublime-workspace
*.sublime-project
workspace.code-workspace
